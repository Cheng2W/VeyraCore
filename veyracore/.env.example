# ============================================
# VeyraCore / 灵枢 - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# Application Settings
# --------------------------------------------
APP_NAME=VeyraCore
APP_VERSION=0.1.0
DEBUG=false

# --------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------
POSTGRES_USER=veyracore
POSTGRES_PASSWORD=veyracore_secret
POSTGRES_DB=veyracore

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_PASSWORD=veyracore_redis_secret

# --------------------------------------------
# Security
# --------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --------------------------------------------
# CORS Origins (comma-separated)
# --------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --------------------------------------------
# AI Service API Keys (25 placeholders)
# Fill in the keys for services you plan to use
# --------------------------------------------

# 1. KeLing AI (可灵)
KELING_API_KEY=

# 2. Tongyi Wanxiang (通义万相)
TONGYI_WANXIANG_API_KEY=

# 3. JiMeng AI (即梦)
JIMENG_API_KEY=

# 4. OpenAI
OPENAI_API_KEY=

# 5. Anthropic
ANTHROPIC_API_KEY=

# 6. Google Gemini
GEMINI_API_KEY=

# 7. Midjourney
MIDJOURNEY_API_KEY=

# 8. Stable Diffusion
STABLE_DIFFUSION_API_KEY=

# 9. DALL-E
DALLE_API_KEY=

# 10. Cohere
COHERE_API_KEY=

# 11. Hugging Face
HUGGINGFACE_API_KEY=

# 12. Replicate
REPLICATE_API_KEY=

# 13. Runway ML
RUNWAY_API_KEY=

# 14. Pika Labs
PIKA_API_KEY=

# 15. ElevenLabs
ELEVENLABS_API_KEY=

# 16. AssemblyAI
ASSEMBLYAI_API_KEY=

# 17. Deepgram
DEEPGRAM_API_KEY=

# 18. Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# 19. Baidu Wenxin (文心一言)
BAIDU_WENXIN_API_KEY=

# 20. Tencent Hunyuan (腾讯混元)
TENCENT_HUNYUAN_API_KEY=

# 21. iFlytek Spark (讯飞星火)
IFLYTEK_API_KEY=

# 22. Zhipu AI (智谱)
ZHIPU_API_KEY=

# 23. Moonshot AI (月之暗面)
MOONSHOT_API_KEY=

# 24. MiniMax
MINIMAX_API_KEY=

# 25. SenseTime (商汤)
SENSETIME_API_KEY=

# --------------------------------------------
# Frontend (Next.js)
# --------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
